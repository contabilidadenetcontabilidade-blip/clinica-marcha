<!DOCTYPE html>
<html lang="pt-BR">

<head>
  <meta charset="UTF-8">
  <title>Marcha Cup</title>
  <link rel="stylesheet" href="cup.css">
  <script src="auth_guard.js"></script>

</head>

<body>
  <header class="global-navbar"
    style="background: #000033; color: white; display: flex; justify-content: space-between; align-items: center; padding: 15px 25px; position: sticky; top: 0; z-index: 1000; box-shadow: 0 4px 6px rgba(0,0,0,0.3);">
    <div class="nav-brand" style="display: flex; align-items: center; gap: 15px; cursor: pointer;"
      onclick="window.location.href='index.html'">
      <img src="../assets/logo_marcha.png" alt="Logo"
        style="height: 40px; filter: drop-shadow(0 0 5px rgba(255,255,255,0.2));">
      <span style="font-size: 1.2rem; font-weight: bold; letter-spacing: 1px;">Marcha</span>
    </div>
    <nav class="nav-links" style="display: flex; gap: 20px; align-items: center;">
      <a href="pacientes.html"
        style="color: #ccc; text-decoration: none; font-weight: 500; font-size: 1rem; transition: 0.2s;">Pacientes</a>
      <a href="agenda.html"
        style="color: #ccc; text-decoration: none; font-weight: 500; font-size: 1rem; transition: 0.2s;">Agenda</a>
      <a href="profissionais.html"
        style="color: #ccc; text-decoration: none; font-weight: 500; font-size: 1rem; transition: 0.2s;">Profissionais</a>
      <a href="financeiro.html"
        style="color: #ccc; text-decoration: none; font-weight: 500; font-size: 1rem; transition: 0.2s;">Financeiro</a>
      <a href="cup.html"
        style="color: white; text-decoration: none; font-weight: 600; font-size: 1rem; border-bottom: 2px solid #FFD700;">Marcha
        Cup</a>
      <button onclick="doLogoff()"
        style="background: #e53935; color: white; border: none; padding: 8px 16px; border-radius: 4px; font-weight: bold; cursor: pointer; margin-left: 10px; transition: 0.2s;">Sair</button>
    </nav>
  </header>
  <script>
    function doLogoff() {
      localStorage.removeItem('user');
      window.location.href = 'login.html';
    }
  </script>

  <main>
    <div class="admin-only" style="display: flex; justify-content: center; gap: 15px; margin-bottom: 20px;">
       <button onclick="openAttendanceModal()" style="background:#FF9800; color:white; padding:10px 20px; border:none; border-radius:6px; cursor:pointer; font-weight:bold; box-shadow: 0 4px 6px rgba(0,0,0,0.3);">
         📋 Lançar Frequência Diária
       </button>
    </div>
    <section class="cup-ranking">
      <h2>Ranking das Casas</h2>
      <ul id="houses-list"></ul>
    </section>
 
     <!-- PROVAS PENDENTES (VAR, TANDERA, ATAQUES) -->
     <section class="card" id="section-provas-pendentes" style="margin-top: 24px; background: rgba(0,0,0,0.2); padding: 15px; border-radius: 12px;">
       <h2 style="font-size: 1.2rem; color: #FFD700; border-bottom: 1px solid #444; padding-bottom: 8px;">⚔️ Provas Pendentes</h2>
       <div id="provas-pendentes-list" style="margin-top: 15px;">
         <p style="color: #888; text-align: center; font-style: italic;">Carregando...</p>
       </div>
     </section>

    <!-- INVENTÁRIO DAS CASAS -->
    <section class="house-inventory"
      style="margin-top: 30px; background: rgba(0,0,0,0.2); padding: 15px; border-radius: 12px;">
      <h2 style="font-size: 1.2rem; color: #FFD700; border-bottom: 1px solid #444; padding-bottom: 8px;">Inventário das
        Equipes (Capitães)</h2>
      <select id="house-select"
        style="width: 100%; padding: 10px; margin: 10px 0; background: #333; color: white; border: 1px solid #555; border-radius: 8px;">
        <option value="">Selecione uma Casa...</option>
      </select>
      <div id="house-cards-grid"
        style="display: flex; flex-wrap: wrap; gap: 10px; justify-content: center; min-height: 50px;">
        <p style="color: #888; font-style: italic;">Selecione uma casa para ver as cartas.</p>
      </div>
    </section>


    <div style="display: flex; gap: 10px; margin-top: 20px;">
      <button class="add-house-btn" onclick="openCreateHouse()"
        style="flex: 1; background: var(--navy); color: var(--white);">
        + Criar Casa
      </button>
      <button class="add-house-btn" onclick="window.location.href='regras.html'"
        style="flex: 1; background: var(--navy); color: var(--white);">
        📜 Regras
      </button>
    </div>
  </main>

  <button id="add-score-btn" class="floating-btn" title="Registrar Pontos" onclick="openAddScore()">
    ➕
  </button>

  <!-- Modal criar casa -->
  <div id="modal-casa" class="modal hidden">
    <div class="modal-content">
      <h3>Nova Casa</h3>
      <form id="form-casa">
        <label>Nome da Casa:</label>
        <input name="name" required>

        <label>Cor da Casa:</label>
        <input type="color" name="color" required>

        <label>Brasão (PNG, máximo 5MB):</label>
        <input type="file" name="crest" accept=".png,image/png" required id="crest-input">
        <small style="color: #666; font-size: 0.85rem;">Apenas arquivos PNG são aceitos</small>

        <button type="submit">Salvar</button>
        <button type="button" onclick="closeCreateHouse()">Cancelar</button>
      </form>
    </div>
  </div>

  <!-- Modal Registrar Pontos -->
  <div id="modal-score" class="modal hidden">
    <div class="modal-content">
      <h3>Registrar Meinhas</h3>
      <form id="form-score">
        <label>Aluno:</label>
        <select name="student_id" id="score-student-select" required>
          <option value="">Carregando...</option>
        </select>

        <label>Regra/Motivo:</label>
        <select name="rule_id" id="score-rule-select" required>
          <option value="">Carregando...</option>
        </select>

        <label>Pontos:</label>
        <input type="text" id="score-points-display" readonly
          style="background: #eee; cursor: not-allowed; width: 60px; text-align: center; margin-bottom: 10px;"
          placeholder="0">

        <button type="submit" style="background: var(--gold); color: #000; font-weight: bold;">Registrar</button>
        <button type="button" onclick="document.getElementById('modal-score').classList.add('hidden')">Cancelar</button>
      </form>
    </div>
  </div>

  <!-- Modal Lançar Frequência -->
  <div id="attendance-modal" class="modal hidden" style="position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.5); z-index:9999;">
    <div style="background:white; margin:5% auto; padding:20px; width:90%; max-width:800px; border-radius:12px; box-shadow: 0 4px 20px rgba(0,0,0,0.3);">
      <h2 style="margin-top:0;">📋 Lançar Frequência</h2>
      
      <label style="font-weight:bold; display:block; margin-bottom:5px;">Filtrar por Casa:</label>
      <select id="attendance-house-filter" onchange="loadAttendanceList()" style="width:100%; padding:10px; border-radius:6px; border:1px solid #ccc; margin-bottom:15px;">
        <option value="0">Todas (Visão Global)</option>
        <option value="1">Joseph</option>
        <option value="2">Cadillac</option>
        <option value="3">Reformer</option>
        <option value="4">Barrel</option>
        <option value="5">Chair</option>
      </select>
      
      <div id="attendance-list" style="max-height:50vh; overflow-y:auto; margin:10px 0; border:1px solid #eee; border-radius:8px; padding:10px;">
        <!-- Renderizado por JS -->
      </div>
      
      <div style="display:flex; justify-content:flex-end; gap:10px; margin-top:20px;">
        <button onclick="saveAttendance()" style="background:#4CAF50; color:white; padding:10px 20px; border:none; border-radius:6px; cursor:pointer; font-weight:bold;">
          ✅ Salvar Rotina
        </button>
        <button onclick="closeAttendanceModal()" style="background:#e53935; color:white; padding:10px 20px; border:none; border-radius:6px; cursor:pointer; font-weight:bold;">
          ❌ Fechar
        </button>
      </div>
    </div>
  </div>

  <script src="utils.js"></script>
  <script src="cup.js"></script>
</body>

</html>